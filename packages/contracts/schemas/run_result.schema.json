{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunResult",
  "type": "object",
  "properties": {
    "runId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "running",
        "succeeded",
        "failed"
      ]
    },
    "ts": {
      "type": "string"
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "runId",
    "status",
    "ts",
    "logs"
  ]
}
